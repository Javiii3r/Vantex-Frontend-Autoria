---
// src/pages/perfil.astro
import Layout from '../layouts/Layout.astro';
import PageHeader from '../components/PageHeader.astro';
import { Icon } from 'astro-icon/components';
---

<Layout title="My Profile">
    <PageHeader title="My Profile" subtitle="Account and security settings" />

    <main class="p-6 md:p-8 max-w-3xl mx-auto w-full space-y-8">
        
        <section class="bg-white dark:bg-zinc-900 rounded-2xl border border-zinc-200 dark:border-zinc-800 shadow-sm overflow-hidden">
            <div class="p-6 border-b border-zinc-100 dark:border-zinc-800 bg-zinc-50/50 dark:bg-zinc-800/30">
                <h3 class="font-bold text-zinc-900 dark:text-zinc-100">Personal Data</h3>
            </div>
            <div class="p-6">
                <form id="form-update-profile" class="space-y-4">
                    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                        <div>
                            <label class="block text-xs font-bold text-zinc-500 dark:text-zinc-400 uppercase mb-1">Full Name</label>
                            <input type="text" name="full_name" id="full_name" required class="w-full px-4 py-2 rounded-lg border border-zinc-200 dark:border-zinc-800 outline-none focus:ring-2 focus:ring-yellow-500 text-sm bg-white dark:bg-zinc-900 dark:text-zinc-100" />
                        </div>
                        <div>
                            <label class="block text-xs font-bold text-zinc-500 dark:text-zinc-400 uppercase mb-1">Email Address</label>
                            <input type="email" name="email" id="email" required class="w-full px-4 py-2 rounded-lg border border-zinc-200 dark:border-zinc-800 outline-none focus:ring-2 focus:ring-yellow-500 text-sm bg-white dark:bg-zinc-900 dark:text-zinc-100" />
                        </div>
                    </div>
                    <div class="flex justify-end pt-2">
                        <button type="submit" class="bg-zinc-900 dark:bg-yellow-500 text-white dark:text-zinc-950 px-6 py-2 rounded-xl font-bold text-sm hover:bg-zinc-800 dark:hover:bg-yellow-400 transition-all">
                            Save Changes
                        </button>
                    </div>
                </form>
            </div>
        </section>

        <section class="bg-white dark:bg-zinc-900 rounded-2xl border border-zinc-200 dark:border-zinc-800 shadow-sm overflow-hidden">
            <div class="p-6 border-b border-zinc-100 dark:border-zinc-800 bg-zinc-50/50 dark:bg-zinc-800/30">
                <h3 class="font-bold text-zinc-900 dark:text-zinc-100">Security</h3>
            </div>
            <div class="p-6">
                <form id="form-update-password" class="space-y-4">
                    <div>
                        <label class="block text-xs font-bold text-zinc-500 dark:text-zinc-400 uppercase mb-1">Current Password</label>
                        <input type="password" name="currentPassword" required class="w-full px-4 py-2 rounded-lg border border-zinc-200 dark:border-zinc-800 outline-none focus:ring-2 focus:ring-yellow-500 text-sm bg-white dark:bg-zinc-900 dark:text-zinc-100" />
                    </div>
                    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                        <div>
                            <label class="block text-xs font-bold text-zinc-500 dark:text-zinc-400 uppercase mb-1">New Password</label>
                            <input type="password" name="newPassword" required class="w-full px-4 py-2 rounded-lg border border-zinc-200 dark:border-zinc-800 outline-none focus:ring-2 focus:ring-yellow-500 text-sm bg-white dark:bg-zinc-900 dark:text-zinc-100" />
                        </div>
                        <div class="flex items-end">
                            <button type="submit" class="w-full bg-zinc-100 dark:bg-zinc-800 text-zinc-900 dark:text-zinc-100 px-6 py-2 rounded-xl font-bold text-sm hover:bg-zinc-200 dark:hover:bg-zinc-700 transition-all border border-zinc-200 dark:border-zinc-700">
                                Change Password
                            </button>
                        </div>
                    </div>
                </form>
            </div>
        </section>

        <div class="bg-white dark:bg-zinc-900 rounded-2xl border border-zinc-200 dark:border-zinc-800 shadow-sm p-2 flex items-center justify-between">
            <span class="text-sm font-medium text-zinc-500 dark:text-zinc-400 pl-4">Current session on this device</span>
            <button id="btn-logout" class="flex items-center gap-2 text-red-600 hover:text-red-700 dark:text-red-400 dark:hover:text-red-300 font-bold px-4 py-2 rounded-xl hover:bg-red-50 dark:hover:bg-red-500/10 transition-all">
                <Icon name="lucide:log-out" class="w-4 h-4" />
                Logout
            </button>
        </div>

        <section id="users-section" class="hidden bg-white dark:bg-zinc-900 rounded-2xl border border-zinc-200 dark:border-zinc-800 shadow-sm overflow-hidden">
            <div class="p-6 border-b border-zinc-100 dark:border-zinc-800 bg-zinc-50/50 dark:bg-zinc-800/30 flex justify-between items-center">
                <h3 class="font-bold text-zinc-900 dark:text-zinc-100">User Management</h3>
                <span class="text-xs bg-zinc-200 dark:bg-zinc-800 text-zinc-600 dark:text-zinc-400 px-2 py-1 rounded-md font-bold" id="users-count">0</span>
            </div>
            <div class="p-4">
                <div id="users-list" class="space-y-3">
                    <p class="text-center text-zinc-400 dark:text-zinc-500 text-sm py-4">Loading users...</p>
                </div>
            </div>
        </section>

        <section class="pt-4 flex flex-col items-center">
            <p class="text-[10px] text-zinc-400 dark:text-zinc-500 mt-4 uppercase tracking-widest">Vantex v1.0.0 - Industrial System</p>
        </section>

    </main>
</Layout>

<script>
    import { redirectIfNotAuthenticated, getUser } from '../lib/auth.js';
    import { setupUserUI } from '../lib/ui.js';
    import { initProfileView } from '../views/perfil.view.js';

    redirectIfNotAuthenticated();

    const user = getUser();
    setupUserUI(user);

    initProfileView();
</script>