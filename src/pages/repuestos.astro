---
// src/pages/repuestos.astro
import Layout from '../layouts/Layout.astro';
import PageHeader from '../components/PageHeader.astro';
import { Icon } from 'astro-icon/components';
---

<Layout title="Spare Parts Inventory">
    <PageHeader title="Spare Parts Warehouse" subtitle="Stock and parts control" />

    <main class="p-6 md:p-8 space-y-6 max-w-7xl mx-auto w-full">
        <div class="grid grid-cols-2 md:grid-cols-4 gap-4" id="stats-container">
            <div class="bg-white dark:bg-zinc-900 p-4 rounded-xl border border-zinc-200 dark:border-zinc-800 shadow-sm">
                <p class="text-xs text-zinc-500 uppercase font-semibold">Total SKUs</p>
                <p class="text-2xl font-bold dark:text-zinc-100" id="stat-total">0</p>
            </div>
            <div class="bg-white dark:bg-zinc-900 p-4 rounded-xl border border-zinc-200 dark:border-zinc-800 shadow-sm">
                <p class="text-xs text-green-600 uppercase font-semibold">Optimal</p>
                <p class="text-2xl font-bold dark:text-zinc-100" id="stat-optimal">0</p>
            </div>
            <div class="bg-white dark:bg-zinc-900 p-4 rounded-xl border border-zinc-200 dark:border-zinc-800 shadow-sm">
                <p class="text-xs text-yellow-600 uppercase font-semibold">Low Stock</p>
                <p class="text-2xl font-bold dark:text-zinc-100" id="stat-low">0</p>
            </div>
            <div class="bg-white dark:bg-zinc-900 p-4 rounded-xl border border-zinc-200 dark:border-zinc-800 shadow-sm">
                <p class="text-xs text-red-600 uppercase font-semibold">Out of Stock</p>
                <p class="text-2xl font-bold dark:text-zinc-100" id="stat-out">0</p>
            </div>
        </div>

        <div class="flex flex-col md:flex-row gap-4 justify-between bg-white dark:bg-zinc-900 p-4 rounded-2xl border border-zinc-200 dark:border-zinc-800">
            <input type="text" id="spare-search" placeholder="Search spare part..." class="px-4 py-2 bg-zinc-50 dark:bg-zinc-900 border border-zinc-200 dark:border-zinc-800 rounded-xl text-sm dark:text-zinc-100 outline-none" />
            <button id="btn-new-spare" class="admin-only bg-yellow-500 hover:bg-yellow-400 text-zinc-950 font-bold py-2.5 px-6 rounded-xl transition-all">
                + New Spare Part
            </button>
        </div>

        <div id="spare-parts-grid" class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6"></div>
    </main>

    <div id="modal-spare" class="fixed inset-0 z-50 hidden flex items-center justify-center p-4 bg-black/60">
        <div class="bg-white dark:bg-zinc-900 rounded-2xl shadow-2xl w-full max-w-md border border-zinc-200 dark:border-zinc-800">
            <div class="p-6 border-b border-zinc-200 dark:border-zinc-800 flex justify-between items-center">
                <h3 class="text-xl font-bold dark:text-zinc-100" id="modal-title">Spare Part Management</h3>
                <button type="button" onclick="document.getElementById('modal-spare').classList.add('hidden')" class="text-zinc-400 hover:text-zinc-600 dark:hover:text-zinc-200 transition-colors">
                    <Icon name="lucide:x" class="size-5" />
                </button>
            </div>
            <form id="form-spare" class="p-6 space-y-4">
                <input type="hidden" id="spare-id" />
                
                <div>
                    <label class="block text-xs font-bold text-zinc-500 uppercase mb-1">SKU (Unique code)</label>
                    <input type="text" id="sku" required class="w-full px-4 py-2 rounded-lg border border-zinc-200 dark:border-zinc-800 bg-white dark:bg-zinc-900 dark:text-zinc-100 text-sm" />
                </div>

                <div>
                    <label class="block text-xs font-bold text-zinc-500 uppercase mb-1">Name</label>
                    <input type="text" id="name" required class="w-full px-4 py-2 rounded-lg border border-zinc-200 dark:border-zinc-800 bg-white dark:bg-zinc-900 dark:text-zinc-100 text-sm" />
                </div>

                <div class="grid grid-cols-2 gap-4">
                    <div>
                        <label class="block text-xs font-bold text-zinc-500 uppercase mb-1">Current Stock</label>
                        <input type="number" id="stock" required class="w-full px-4 py-2 rounded-lg border border-zinc-200 dark:border-zinc-800 bg-white dark:bg-zinc-900 dark:text-zinc-100 text-sm" />
                    </div>
                    <div>
                        <label class="block text-xs font-bold text-zinc-500 uppercase mb-1">Minimum Stock</label>
                        <input type="number" id="minimum_stock" required class="w-full px-4 py-2 rounded-lg border border-zinc-200 dark:border-zinc-800 bg-white dark:bg-zinc-900 dark:text-zinc-100 text-sm" />
                    </div>
                </div>

                <div>
                    <label class="block text-xs font-bold text-zinc-500 uppercase mb-1">Unit Price (€)</label>
                    <input type="number" step="0.01" id="unit_price" required class="w-full px-4 py-2 rounded-lg border border-zinc-200 dark:border-zinc-800 bg-white dark:bg-zinc-900 dark:text-zinc-100 text-sm" />
                </div>

                <button type="submit" class="w-full bg-zinc-900 dark:bg-yellow-500 text-white dark:text-zinc-950 font-bold py-3 rounded-xl">Save</button>
            </form>
        </div>
    </div>

    <div id="modal-label" class="fixed inset-0 z-50 hidden flex items-center justify-center p-4 bg-black/60">
        <div class="bg-white dark:bg-zinc-900 rounded-2xl shadow-2xl w-full max-w-sm border border-zinc-200 dark:border-zinc-800">
            <div class="p-6 border-b border-zinc-200 dark:border-zinc-800 flex justify-between items-center">
                <h3 class="text-xl font-bold dark:text-zinc-100">Spare Part Label</h3>
                <button type="button" onclick="document.getElementById('modal-label').classList.add('hidden')" class="text-zinc-400 hover:text-zinc-600 dark:hover:text-zinc-200 transition-colors">
                    <Icon name="lucide:x" class="size-5" />
                </button>
            </div>
            <div class="p-6 flex flex-col items-center gap-4">
                <div id="print-area" class="flex flex-col items-center gap-3 p-6 border-2 border-dashed border-zinc-200 dark:border-zinc-700 rounded-xl w-full">
                    <canvas id="qr-canvas"></canvas>
                    <p id="label-sku" class="font-mono text-sm font-bold dark:text-zinc-100"></p>
                    <p id="label-name" class="text-xs text-zinc-500 text-center max-w-[180px]"></p>
                </div>
                <div class="flex gap-3 w-full mt-2">
                    <button onclick="window.print()" class="w-full flex items-center justify-center gap-2 bg-yellow-500 hover:bg-yellow-400 text-zinc-950 py-3 rounded-xl font-bold">
                        <Icon name="lucide:printer" class="size-5" /> Print Label
                    </button>
                </div>
            </div>
        </div>
    </div>
</Layout>

<script>
    import { redirectIfNotAuthenticated } from '../lib/auth.js';
    import { setupUserUI, applyRoleProtections } from '../lib/ui.js';
    import { initSparePartsView } from '../views/repuestos.view.js';
    import { getUser } from '../lib/auth.js';
    redirectIfNotAuthenticated();
    setupUserUI(getUser());
    applyRoleProtections(getUser());
    await initSparePartsView();
</script>

<style is:global>
    @media print {
        body * { visibility: hidden; }
        #print-area, #print-area * { visibility: visible; }
        #print-area { position: absolute; left: 50%; top: 50%; transform: translate(-50%, -50%); border: none; }
    }
</style>