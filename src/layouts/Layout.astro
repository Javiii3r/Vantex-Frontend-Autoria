---
import '../styles/global.css';

interface Props {
	title: string;
}

const { title } = Astro.props;
---

<!doctype html>
<html lang="es">
	<head>
		<meta charset="UTF-8" />
		<meta name="description" content="VantexCorp - Sistema GMAO" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="generator" content={Astro.generator} />
		<title>{title} | VantexCorp</title>
	</head>
	<body class="bg-zinc-950 text-white min-h-screen flex overflow-hidden font-sans antialiased selection:bg-purple-500/30">
		<!-- Efectos de iluminación de fondo tipo Glassmorphism (guardando tu estilo) -->
		<div class="fixed top-[-10%] left-[-10%] w-[500px] h-[500px] bg-purple-600/20 rounded-full blur-[120px] -z-10 pointer-events-none"></div>
		<div class="fixed -bottom-32 -right-32 w-[600px] h-[600px] bg-blue-600/10 rounded-full blur-[120px] -z-10 pointer-events-none"></div>
		
		<main class="flex-1 w-full h-full overflow-y-auto relative z-10 flex flex-col">
			<slot />
		</main>
	</body>
</html>
