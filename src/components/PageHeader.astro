---
interface Props {
  title: string;
  subtitle?: string;
  showDate?: boolean;
}

const { title, subtitle, showDate = false } = Astro.props;
---

<header class="sticky top-0 z-20 bg-white/80 dark:bg-zinc-950/80 backdrop-blur-md border-b border-zinc-200 dark:border-zinc-800 shrink-0">
  <div class="max-w-7xl mx-auto px-6 md:px-12 lg:px-20 py-4 flex items-center justify-between">
    <div>
      <h1 class="text-xl font-bold text-zinc-900 dark:text-zinc-100">{title}</h1>
      {subtitle && <p class="text-sm text-zinc-500 dark:text-zinc-400">{subtitle}</p>}
    </div>
    <div class="flex items-center gap-4">
      {showDate && <span class="hidden sm:inline text-xs text-zinc-400 dark:text-zinc-500" id="current-date"></span>}
      <div class="flex items-center gap-2 sm:pl-4 sm:border-l border-zinc-200 dark:border-zinc-800">
        <div class="w-8 h-8 rounded-full bg-yellow-500/20 border border-yellow-500/40 flex items-center justify-center">
          <span class="text-yellow-600 font-bold text-xs" id="header-avatar">?</span>
        </div>
        <div class="hidden sm:block">
          <p class="text-sm font-medium text-zinc-800 dark:text-zinc-200 leading-tight" id="header-name">—</p>
          <p class="text-xs text-zinc-500 dark:text-zinc-400 leading-tight" id="header-role">—</p>
      </div>
    </div>
  </div>
</header>
