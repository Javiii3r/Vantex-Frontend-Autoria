---
// src/components/Sidebar.astro
import { Icon } from "astro-icon/components";

const pathname = Astro.url.pathname;
const isDashboard = pathname === "/dashboard";
const isWorkOrders = pathname.startsWith("/ordenes");
const isMachines = pathname.startsWith("/maquinas");
const isSpareParts = pathname.startsWith("/repuestos");
const navItems = [
	{
		href: "/dashboard",
		label: "Dashboard",
		active: isDashboard,
		icon: "lucide:layout-dashboard",
	},
	{
		href: "/ordenes",
		label: "Work Orders",
		active: isWorkOrders,
		icon: "lucide:clipboard-list",
	},
	{
		href: "/maquinas",
		label: "Machines",
		active: isMachines,
		icon: "lucide:cpu",
	},
	{
		href: "/repuestos",
		label: "Inventory",
		active: isSpareParts,
		icon: "lucide:package",
	},
];
---

<aside
	class="group fixed bottom-0 left-0 w-full md:relative md:w-20 md:hover:w-64 h-16 md:h-screen md:min-h-screen bg-zinc-950 border-t md:border-t-0 md:border-r border-white/10 flex flex-row md:flex-col md:py-6 transition-all duration-300 md:hover:duration-500 delay-0 md:hover:delay-300 ease-in-out z-50 overflow-hidden shrink-0"
>
	<!-- Logo / Marca (Oculto en móvil) -->
	<a
		href="/dashboard"
		class="hidden md:flex items-center mb-8 px-5 w-full cursor-pointer"
	>
		<div class="min-w-10 h-10 flex items-center justify-center">
			<img src="/vvVantex.png" alt="Logo" class="w-10 h-10" />
		</div>
		<span
			class="ml-4 text-xl font-bold tracking-tight text-white opacity-0 group-hover:opacity-100 transition-opacity duration-300 md:group-hover:duration-500 delay-0 md:group-hover:delay-300 whitespace-nowrap"
		>
			VantexCorp
		</span>
	</a>

	<!-- Avatar del Usuario (Oculto en móvil) -->
	<div class="hidden md:flex items-center mb-6 px-5 w-full overflow-hidden">
		<div
			class="min-w-10 h-10 rounded-full bg-yellow-500/20 border border-yellow-500/30 flex items-center justify-center shrink-0"
		>
			<span class="text-yellow-400 font-bold text-sm" id="user-avatar"
				>?</span
			>
		</div>
		<div
			class="ml-3 opacity-0 group-hover:opacity-100 transition-opacity duration-300 md:group-hover:duration-500 delay-0 md:group-hover:delay-300 whitespace-nowrap overflow-hidden"
		>
			<p class="text-sm font-semibold text-white truncate" id="user-name">
				Loading...
			</p>
			<p class="text-xs text-zinc-400 truncate" id="user-role">—</p>
		</div>
	</div>

	<!-- Divisor (Oculto en móvil) -->
	<div class="hidden md:block mx-4 mb-4 border-t border-white/10"></div>

	<!-- Menú de Navegación Principal -->
	<nav
		class="flex flex-row md:flex-col justify-around md:justify-start gap-1 w-full px-1 md:px-3 flex-1 items-center md:items-stretch"
	>
		{
			navItems.map(({ href, label, active, icon }) => (
				<a
					href={href}
					class={`flex flex-col md:flex-row items-center justify-center md:justify-start w-16 md:w-full rounded-xl transition-all duration-200 py-2 md:py-3 ${active ? "bg-yellow-500/10" : "hover:bg-white/5"}`}
				>
					<div class="flex items-center justify-center mb-1 md:mb-0 md:min-w-14">
						<Icon
							name={icon}
							class={`w-5 h-5 md:w-6 md:h-6 ${active ? "text-yellow-400" : "text-zinc-400"}`}
						/>
					</div>
					<span
						class={`text-[10px] md:text-sm font-medium md:opacity-0 md:group-hover:opacity-100 transition-opacity duration-300 md:group-hover:duration-500 delay-0 md:group-hover:delay-300 whitespace-nowrap ${active ? "text-yellow-400 font-semibold" : "text-zinc-400 md:text-zinc-300"}`}
					>
						<span class="md:hidden">{label.split(" ")[0]}</span>
						<span class="hidden md:inline">{label}</span>
					</span>
				</a>
			))
		}

		<!-- Footer Sidebar: Profile (Móvil) -->
		<a
			href="/perfil"
			class="flex md:hidden flex-col items-center justify-center w-16 rounded-xl transition-all duration-200 hover:bg-yellow-500/10 py-2 cursor-pointer"
		>
			<div class="flex items-center justify-center mb-1">
				<Icon
					name="lucide:user"
					class="w-5 h-5 text-zinc-500 hover:text-yellow-400 transition-colors"
				/>
			</div>
			<span class="text-[10px] text-zinc-400 font-medium">Profile</span>
		</a>

		<!-- Selector de Tema (Móvil) -->
		<button
			id="theme-toggle-mobile"
			class="flex md:hidden flex-col items-center justify-center w-16 rounded-xl transition-all duration-200 hover:bg-yellow-500/10 py-2 cursor-pointer"
		>
			<div class="flex items-center justify-center mb-1">
				<Icon
					name="lucide:sun"
					class="w-5 h-5 text-yellow-500 dark:hidden"
				/>
				<Icon
					name="lucide:moon"
					class="w-5 h-5 text-yellow-400 hidden dark:block"
				/>
			</div>
			<span
				class="text-[10px] text-zinc-400 font-medium dark:text-yellow-400/70"
				>Theme</span
			>
		</button>
	</nav>

	<!-- Footer Sidebar: Theme & Profile (Desktop) -->
	<div class="hidden md:block w-full px-3 mt-4 border-t border-white/10 pt-4">
		<!-- Theme Toggle Desktop -->
		<button
			id="theme-toggle-desktop"
			class="flex items-center w-full rounded-xl transition-all duration-200 hover:bg-white/5 py-3 cursor-pointer mb-2"
		>
			<div class="min-w-14 flex items-center justify-center">
				<Icon
					name="lucide:sun"
					class="w-6 h-6 text-yellow-500 dark:hidden"
				/>
				<Icon
					name="lucide:moon"
					class="w-6 h-6 text-yellow-400 hidden dark:block"
				/>
			</div>
			<span
				class="ml-1 text-sm font-medium text-zinc-400 opacity-0 group-hover:opacity-100 transition-opacity duration-300 md:group-hover:duration-500 delay-0 md:group-hover:delay-300 whitespace-nowrap"
			>
				Theme
			</span>
		</button>

		<a
			href="/perfil"
			class="flex items-center w-full rounded-xl transition-all duration-200 hover:bg-yellow-500/10 py-3 cursor-pointer"
		>
			<div class="min-w-14 flex items-center justify-center">
				<Icon
					name="lucide:user"
					class="w-6 h-6 text-zinc-500 group-hover:text-yellow-400 transition-colors"
				/>
			</div>
			<span
				class="ml-1 text-sm font-medium text-zinc-400 opacity-0 group-hover:opacity-100 transition-opacity duration-300 md:group-hover:duration-500 delay-0 md:group-hover:delay-300 whitespace-nowrap"
			>
				My Profile
			</span>
		</a>
	</div>
</aside>

<script>
	import { toggleTheme } from "../lib/ui.js";

	const btnDesktop = document.getElementById("theme-toggle-desktop");
	const btnMobile = document.getElementById("theme-toggle-mobile");

	const handleToggle = () => {
		toggleTheme();
	};

	btnDesktop?.addEventListener("click", handleToggle);
	btnMobile?.addEventListener("click", handleToggle);
</script>
